# Minimal SWE Agent — environment variables
# Copy this file to .env and fill in your values.

# LLM Configuration
LLM_MODEL=deepseek/deepseek-v4-flash
LLM_API_KEY=sk-your-key-here
LLM_API_BASE=https://api.deepseek.com
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2

# Memory Configuration
MEMORY_ENABLED=true
MEMORY_DIRECTORY=~/.minimal-swe-agent/memories

# Agent Configuration
AGENT_MAX_ITERATIONS=10
AGENT_WORKSPACE_DIR=.
